{
  "name": "redash-mcp",
  "version": "1.0.0",
  "description": "Read-only MCP server for Redash",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "redash-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "husky",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,js,mts,mjs}": ["biome check --write --no-errors-on-unmatched"]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
